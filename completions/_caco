_caco_cache() {
    local -a subcmds
    subcmds=(
        'list:List cached files'
        'clear:Remove cached files'
        'prune:Remove orphaned files'
    )

    if (( CURRENT == 2 )); then
        _describe 'cache command' subcmds
        return
    fi

    local subcmd="${words[2]}"
    (( CURRENT-- ))
    shift words

    case "$subcmd" in
        list)
            _arguments \
                '(-o --output)'{-o,--output}'[Output format]:format:(plain json table)' \
                '--orphans[Show orphaned files]' \
                '--help[Show help]'
            ;;
        clear)
            _arguments \
                '--all[Clear entire cache]' \
                '--dry-run[Show what would be deleted]' \
                '(-y --yes)'{-y,--yes}'[Skip confirmation]' \
                '--help[Show help]'
            ;;
        prune)
            _arguments \
                '--dry-run[Show what would be deleted]' \
                '(-y --yes)'{-y,--yes}'[Skip confirmation]' \
                '--help[Show help]'
            ;;
    esac
}

