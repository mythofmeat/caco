# ---------------------------------------------------------------------------
# Main dispatcher
# ---------------------------------------------------------------------------

_caco() {
    local state

    local -a commands
    commands=(
        'ls:List WADs in your library'
        'info:Show details about a WAD'
        'modify:Modify WAD metadata'
        'trash:Manage trash and removals'
        'play:Play a WAD'
        'import:Import WADs from various sources'
        'config:View or edit configuration'
        'random:Pick a random WAD'
        'completions:Generate shell completions'
        'stats:Show library statistics'
        'cache:Manage WAD file cache'
        'enrich:Re-run enrichment for existing WADs'
        'companion:Manage companion files'
        'gc:Garbage collect finished/abandoned WAD data'
        'collection:Manage smart collections'
        'profile:Manage sourceport config profiles'
        'saves:Manage save files'
        'demos:Manage demo files'
        'sessions:Show play sessions'
    )

    if (( CURRENT == 2 )); then
        _describe 'caco command' commands
        local -a options
        options=(
            '--tui:Launch TUI interface'
            '--gui:Launch GUI interface'
            '--help:Show help'
        )
        _describe 'option' options
        return
    fi

    local cmd="${words[2]}"
    (( CURRENT-- ))
    shift words

    case "$cmd" in
        ls) _caco_ls ;;
        info) _caco_info ;;
        modify) _caco_modify ;;
        trash) _caco_trash ;;
        play) _caco_play ;;
        import) _caco_import ;;
        config) _caco_config ;;
        completions) _caco_completions ;;
        random) _caco_random ;;
        stats) _caco_stats ;;
        cache) _caco_cache ;;
        enrich) _caco_enrich ;;
        companion) _caco_companion ;;
        gc) _caco_gc ;;
        collection) _caco_collection ;;
        profile) _caco_profile ;;
        saves) _caco_saves ;;
        demos) _caco_demos ;;
        sessions) _caco_sessions ;;
    esac
}

_caco "$@"
